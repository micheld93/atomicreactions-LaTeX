%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Bohrmodel with charge and shell %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Main command:
% #1 = Element
% #2 = Charge (integer: negative, zero, positive)
% #3 = comma-separated shell populations
%
\NewDocumentCommand{\bohrModel}{mmm}{%
	\begin{tikzpicture}[scale=1]
		% Parameters
		\def\radiusstep{0.8}
		\def\esize{2pt}
		% Loop over shells
		\foreach \electrons [count=\n] in {#3} {
			
			\pgfmathsetmacro{\r}{\n * \radiusstep}
			
			% Draw shell
			\draw[gray!60] (0,0) circle (\r);
			
			% Draw electrons
			\foreach \i in {1,...,\electrons} {
				\pgfmathsetmacro{\angle}{360/\electrons * (\i-1)}
				\fill ({\r*cos(\angle)}, {\r*sin(\angle)}) circle (\esize);
			}
		}
		
		% Charge formatting
		\ifnum#2=0
		\node at (0,0) {\Large #1};
		\else
		\ifnum#2>0
		\node at (0,0) {\Large $#1^{#2+}$};
		\else
		\pgfmathtruncatemacro{\abscharge}{abs(#2)}
		\node at (0,0) {\Large $#1^{\abscharge-}$};
		\fi
		\fi
		
	\end{tikzpicture}
}





